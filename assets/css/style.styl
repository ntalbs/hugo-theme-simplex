/* style.styl */

/* General - Setting up some base styles */

*
  -webkit-box-sizing border-box
  -moz-box-sizing border-box
  box-sizing border-box

html
  font-size 10px
  height 100%
  max-height 100%
  font-family sans-serif

body
  font-size clamp(1.3rem, 5vw, 1.9rem)
  line-height 1.6em
  height 100%
  max-height 100%
  margin 0
  background-color var(--background)

.clearfix
  overflow

.unselectable
  user-select none
  outline none

h1, h2, h3, h4, h5, h6
  text-rendering optimizeLegibility
  text-align left
  line-height 1
  font-family 'Open Sans', sans-serif
  font-weight bold
  color var(--heading)
  margin-top 1.6em

h1, h2.post-title
  font-size clamp(2.4rem, 7vw + 1rem, 2.8rem)
  line-height 1.2em
  letter-spacing -2px
  margin-left -2px
  border var(--h1-border)

h1.none
  display none

h2
  font-size clamp(2rem, 6vw + 1rem, 2.4rem)
  line-height 1.2em
  letter-spacing -1px

h3
  font-size clamp(1.8rem, 5vw + 1rem, 2rem)

h4
  font-size clamp(1.6rem, 4vw + 1rem, 1.8rem)

h5
  font-size clamp(1.4rem, 3vw + 1rem, 1.6rem)

h6
  font-size clamp(1.2rem, 2vw + 1rem, 1.4rem)

img
  &.right
    float right
  max-width 100%
  display block
  margin-left auto
  margin-right auto
  filter brightness(var(--img-brightness))
  &.invert-safe
    filter invert(var(--invert-amt))

p
  text-align justify

ul, ol
  padding-inline-start 1.5em

a
  color var(--link)
  transition color ease 0.3s
  &:hover
    color var(--link-hover)

.footnote-ref
  padding-top 88px

strong
  font-weight bold

em
  font-style italic

p, ul, ol, dl
  margin 1.2em 0
  color var(--text)

ol ol, ul ul, ul ol, ol ul
  margin 0.4em 0

li p
  margin 0

hr
  display block
  height 1px
  border 0
  border-top 1px dashed #efefef
  padding 0

figure
  text-align right
  figcaption
    font-family sans-serif
    font-style italic
    color gray
    font-size 0.6em

blockquote
  box-sizing border-box
  margin 1.6em 0 1.6em 0
  padding 0.4em 0.6em
  color var(--text)
  background-color var(--box-bg)
  ul, ol
    margin-top 0
    margin-bottom 5px
  p
    text-align left
    margin 0
  small
    display inline-block
    margin 0.8em 0 0.8em 1.5em
    font-size:0.8em
    color #ccc
    &:before
      content '\2014 \00A0'
  cite
    font-weight bold
    a
      font-weight normal
  &.right-align
    text-align right

.button-box
  text-align right

.highlight pre
  padding 5px 10px
  font-size 1.4rem
  letter-spacing -1px
  overflow auto

p code, li code
  padding 3px 3px 1px 3px
  font-size 0.8em
  white-space pre-line
  border none
  color var(--text)
  background var(--inline-code-bg)
  border-radius 3px
  hyphens none
  text-align left

pre
  -moz-box-sizing border-box
  box-sizing border-box
  margin 0
  padding 0
  font-family SFMono-Regular,Consolas,Liberation Mono,Menlo,monospace
  color var(--Foreground)
  background-color var(--Background)
  font-size 0.8em
  line-height 1.2em
  white-space pre
  word-break normal
  letter-spacing -1px
  overflow scroll
  &.console, &.example
    font-size 1.4rem
    padding 10px
    letter-spacing -1px
    overflow auto
  &.example
    border-top 1px solid var(--line)
    border-bottom 1px solid var(--line)
    filter brightness(98%)
    &:before
      content: "output ==> "
  &.sql-output
    &:before
      content: "output ==> \A"

table
  font-size 1.7rem
  box-sizing border-box
  margin 1.6em 0
  width 100%
  max-width 100%
  border-collapse: collapse
  border 1px solid var(--line)
  color var(--text)
  th, td
    padding 0 8px
  td
    border-top 1px solid var(--line)
  thead
    background-color rgba(64,64,64,0.1)
  tbody > tr:nth-child(even)
    background-color rgba(221,221,221,0.1)

twitter-widget, video
  display block
  margin auto
  max-width 95%

/* General - The main styles for thie theme */
.navbar
  display flex
  align-items center
  font-size 1.8rem
  border 1px solid transparent
  margin-bottom 20px
  min-height 50px
  background-color var(--navbar-bg)
  border-color #333
  border-width 0 0 1px
  top 0
  left 0
  right 0
  transform translate3d(0,0,0)
  -webkit-transform translate3d(0,0,0)
  z-index 1030
  .container
    display flex
    align-items center
    width 100%

.navbar-brand
  margin-right auto
  text-decoration none
  white-space nowrap
  color #bbb
  font-size 18px
  height 50px
  line-height 20px
  padding 15px
  margin-left -15px
  &:focus, &:hover
    text-shadow 0 0 5px
    text-decoration none
    color #eee

.navbar-items
  margin-left auto
  display flex
  align-items center
  .nav-item
    margin 0 clamp(5px, 4vw, 10px)
    font-size 1.8rem

  input.nav-item
    font-size 1.5rem
    padding 5px
    border none
    border-radius 5px
    outline 0
    background-color lightgray
    max-width 180px
  a.nav-item
    color #bbb
    text-decoration none
    &:focus, &:hover
      color #eee
      outline none
      text-shadow 0 0 8px
      svg
        filter drop-shadow(0px 0px 5px #fff)
        border 0
  #mode-switch.nav-item
    display inline-flex
    background rgba(0, 0, 0, 0)
    padding-top 2px
    border 0

.page-head
  position relative
  box-sizing border-box
  display table
  width 100%
  height 50px

.blog-description
  font-size clamp(1rem, 2vw, 1.6rem)
  line-height clamp(1rem, 2vw, 2rem)
  margin-top -15px
  color #aaa

.post .post-excerpt
  h1,h2,h3,h4,h5,h6,img,blockquote
    display none

.pagination
  display block
  text-align center
  list-style-type none
  padding 0
  li
    display inline-block
    margin 0
    a
      padding 3px 6px
      text-decoration none


/* Every post, on every page */
.post
  clear right
  text-align justify
  position relative
  padding-bottom 2rem
  border-bottom var(--line) 1px solid
  margin-bottom 2rem
  word-break break-word
  hyphens auto
  li
    text-align left
  /* Add a little circle in the middle of the border-bottom on our .post
     just for the lolz and stylepoints. */

  &:after
    display block
    content ""
    width 7px
    height 7px
    border var(--line) 1px solid
    position absolute
    bottom -5px
    left 50%
    margin-left -5px
    background var(--background)
    -webkit-border-radius 100%
    -moz-border-radius 100%
    border-radius 100%
    box-shadow var(--background) 0 0 0 5px

.post-content, .post-excerpt
  font-family MaruBuriLight, serif

.post-footer
  padding 4rem 0

#progress
  overflow hidden
  left 0
  position fixed
  height 8px
  width 100%
  background var(--progress-bg)
  z-index 900
  -moz-transition all .3s ease
  -ms-transition all .3s ease
  -o-transition all .3s ease
  transition all .3s ease

#scroll-title
  color white
  position absolute
  top 0px
  padding 5px 0

#bar
  // background-color #089378
  // background-color #0898b3
  background-color #888
  width 0
  height 100%
  position absolute
  top 0
  -webkit-transition all .3s
  -moz-transition all .3s
  -o-transition all .3s
  -ms-transition all .3s
  transition all .3s

/* Every post in `archive` page */
.post-archive
  clear right
  text-align left
  position relative
  padding-bottom 2rem
  word-break break-word
  hyphens auto

.post-title a
  text-decoration none

.post-meta
  display inline-block
  font-size 1.6rem
  padding-top 0
  margin-top 0
  margin-bottom 0
  color var(--post-meta)
  +h1, +h2
    margin-top 0

.draft
  color #FF4500

.widget
  padding-bottom 30px
  border-bottom 1px solid gray
  margin-bottom 30px

.tag-box, .post-meta
  margin 0
  overflow hidden
  &.inline li
    float left
  a
    font-size 0.8em
    padding 2px 6px
    margin 2px
    color var(--tagbox)
    border-radius 5px
    text-decoration none
    border 1px dotted #bbb
    &:hover
      color #fff
      background-color #999
      border 1px solid #888
    sup
      &:before
        content "("
      &:after
        content ")"

.list-unstyled
  list-style none
  padding-left 0

.archive-ul
  font-size 2.4rem
  font-weight bold
  color var(--archive-ul)
  cursor pointer
  &:before
    content ""
    display block
    height 50px
    margin -50px 0 0

.listing-item
  color var(--text)
  .post-title
    margin-top 0
    margin-bottom 5px
    font-size clamp(1.4rem, 4vw, 1.9rem)
    line-height 1
    text-align left
  .post-meta
    vertical-align middle
    &:after
      content " "
      white-space pre

/* from bootstrap */
.caret
  display inline-block
  width 0
  height 0
  margin-left 2px
  vertical-align middle
  border-top 5px solid
  border-right 5px solid transparent
  border-left 5px solid transparent

#article-nav
  border-top 1px solid #ebf2f6
  padding-top 20px
  &:after
    clear both

#article-nav-newer
  float left
  text-decoration none
  margin-right 10px
  &:before
    content "< "
    vertical-align top
    font-weight bold

#article-nav-older
  float right
  text-decoration none
  text-align right
  margin-left 10px
  &:after
    content " >"
    vertical-align top
    font-weight bold

/* Pagination */

#page-nav
  width: 100%
  margin-top 30px
  text-align center
  a
    vertical-align middle
    text-decoration none
  .page-number, .prev, .next
    font-size 90%
    margin-left 5px
    margin-right 5px
  .prev, .next
    white-space nowrap
    vertical-align top
    font-size 16.2px
  .prev
    margin-right 20px
    margin-right 5px
    vertical-align top
    font-weight bold
  .next
    margin-left 20px
    margin-left 5px
    vertical-align top
    font-weight bold

.label
  border-radius .25em
  color #fff
  background-color #aaa
  display inline
  font-size 75%
  font-weight bold
  line-height 1
  padding .2em .6em .3em
  text-align center
  vertical-align baseline
  white-space nowrap

.label-danger
  background-color #d9534f

.label-primary
  background-color #428bca

.label-info
  background-color #5bc0de

#comment
  clear both
  padding-top 50px

/* Footer */

.page-bottom
  position relative
  margin 8rem 0 0 0
  padding 4rem 0
  font-family 'Open Sans', sans-serif
  font-size 1.5rem
  line-height 1.7em
  color #aaa
  background-color var(--footer-bg)
  text-align center
  a
    color #aaa
    text-decoration underline
    &:hover
      text-shadow 0 0 5px
      color #eee

.poweredby
  .icon-ghost
    font-weight 700
    text-decoration none
  .icon-ghost:hover
    text-decoration none
  .icon-ghost:before
    font-size 1rem
    margin-right 0.2em

/* Override bootstrap classes */
.container
  max-width 720px
  margin-left auto
  margin-right auto
  padding-left 15px
  padding-right 15px

.navbar-nav>li>a
  font-size 1.8rem

.navbar-toggle
  display none

.hidden
  display none!important
  visibility hidden!important

.collapsed
  max-height 0
  &.in
    overflow hidden

@media only screen and (max-width: 600px)
  .navbar-items
    #search
      display none

  img.right
    float none
